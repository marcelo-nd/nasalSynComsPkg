)
} else {
p1 <- p1 + geom_bar(aes(x = sample, y = abundance, fill = species2),
position = "fill", stat = "identity", color = "black", linewidth = 0.1)
}
p1 <- p1 + scale_fill_manual(values = colour_palette, name = "Species")
if (!is.null(metadata_df)) {
p1 <- p1 +
new_scale_fill() +
